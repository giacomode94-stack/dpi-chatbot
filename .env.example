# ─── VARIABILI AMBIENTE PER RENDER.COM ───────────────────────────────────────
# Copia questi valori nelle Environment Variables di Render

# Token temporaneo generato su Meta Developer Portal
WHATSAPP_TOKEN=il_tuo_token_qui

# ID del numero di telefono (trovato su Configurazione API)
PHONE_NUMBER_ID=122425334097820

# Token segreto per verificare il webhook (puoi sceglierlo tu)
VERIFY_TOKEN=dpi_chatbot_token

# Porta (Render la gestisce automaticamente)
PORT=3000
